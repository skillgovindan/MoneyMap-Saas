{
  "info": {
    "name": "MoneyMap Saas - Complete API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Income",
      "item": [
        {
          "name": "Create Income",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"title\": \"Salary\",\n  \"amount\": 25000,\n  \"category\": \"Job\",\n  \"date\": \"2026-04-30\",\n  \"description\": \"Monthly salary\",\n  \"paymentMethod\": \"Bank\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/income","host": ["{{baseUrl}}"],"path": ["api","income"]}
          }
        },
        {
          "name": "Get All Income",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/income","host": ["{{baseUrl}}"],"path": ["api","income"]}
          }
        },
        {
          "name": "Get Income By ID",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/api/income/{{incomeId}}","host": ["{{baseUrl}}"],"path": ["api","income","{{incomeId}}"]}
          }
        },
        {
          "name": "Update Income",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"title\": \"Freelance Work\",\n  \"amount\": 12000,\n  \"category\": \"Freelance\",\n  \"date\": \"2026-04-30\",\n  \"description\": \"Website work payment\",\n  \"paymentMethod\": \"UPI\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/income/{{incomeId}}","host": ["{{baseUrl}}"],"path": ["api","income","{{incomeId}}"]}
          }
        },
        {
          "name": "Patch Income",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type","value": "application/json"}],
            "body": {"mode": "raw","raw": "{\n  \"amount\": 15000\n}"},
            "url": {"raw": "{{baseUrl}}/api/income/{{incomeId}}","host": ["{{baseUrl}}"],"path": ["api","income","{{incomeId}}"]}
          }
        },
        {
          "name": "Delete Income",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{baseUrl}}/api/income/{{incomeId}}","host": ["{{baseUrl}}"],"path": ["api","income","{{incomeId}}"]}
          }
        }
      ]
    },
